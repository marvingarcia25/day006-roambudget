@page
@model RoamBudget.Pages.IndexModel
@{
    Layout = "_Layout";
}

<div class="app">

  <!-- HEADER -->
  <header class="app-header">
    <div class="header-row">
      <div class="header-brand">
        <div class="brand-icon">✈️</div>
        <span class="brand-title">Roam<em>Budget</em></span>
      </div>
      <button class="btn-new-trip" id="btnNewTrip" onclick="openModal('tripModal')">
        + New Trip
      </button>
    </div>
  </header>

  <!-- ══ TAB: TRIPS ═══════════════════════════════════════════ -->
  <div class="tab-panel active" id="tab-trips">
    <div id="tripsList"></div>
  </div>

  <!-- ══ TAB: EXPENSES ════════════════════════════════════════ -->
  <div class="tab-panel" id="tab-expenses">
    <div class="expenses-header">
      <div class="active-trip-badge">
        <span class="active-trip-name" id="expTrip">—</span>
        <span class="spent-badge" id="expSpentBadge"></span>
      </div>
      <button class="btn-add" onclick="openModal('expenseModal')">+ Add</button>
    </div>
    <div class="expense-list" id="expenseList"></div>
  </div>

  <!-- ══ TAB: BUDGET ══════════════════════════════════════════ -->
  <div class="tab-panel" id="tab-budget">
    <select class="budget-trip-select" id="budgetTripSelect" onchange="loadBudget(this.value)"></select>
    <div id="budgetContent"></div>
  </div>

  <!-- ══ TAB: PROFILE ═════════════════════════════════════════ -->
  <div class="tab-panel" id="tab-profile">
    <div class="profile-header">
      <div class="profile-logo">✈️</div>
      <div class="profile-name">Roam<em>Budget</em></div>
      <div class="profile-tagline">Travel More. Spend Smarter.</div>
    </div>
    <div class="stats-grid" id="profileStats"></div>
    <div class="recent-section-label">Recent Expenses</div>
    <div class="expense-list" id="recentExpenses"></div>
  </div>

</div><!-- /.app -->

<!-- BOTTOM NAV -->
<nav class="bottom-nav">
  <button class="nav-btn active" id="nav-trips" onclick="switchTab('trips')">
    <span class="nav-icon">🧳</span>
    <span class="nav-label">Trips</span>
  </button>
  <button class="nav-btn" id="nav-expenses" onclick="switchTab('expenses')">
    <span class="nav-icon">💳</span>
    <span class="nav-label">Expenses</span>
  </button>
  <button class="nav-btn" id="nav-budget" onclick="switchTab('budget')">
    <span class="nav-icon">📊</span>
    <span class="nav-label">Budget</span>
  </button>
  <button class="nav-btn" id="nav-profile" onclick="switchTab('profile')">
    <span class="nav-icon">👤</span>
    <span class="nav-label">Profile</span>
  </button>
</nav>

<!-- ══ MODAL: NEW TRIP ══════════════════════════════════════════ -->
<div class="modal-overlay hidden" id="tripModal" onclick="if(event.target===this) closeModal('tripModal')">
  <div class="modal">
    <div class="modal-handle"></div>
    <div class="modal-header">
      <span class="modal-title">New Trip</span>
      <button class="modal-close" onclick="closeModal('tripModal')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Trip Name *</label>
        <input class="form-input" type="text" id="t-name" placeholder="e.g. Santorini Getaway" />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Date Range</label>
          <input class="form-input" type="text" id="t-dates" placeholder="e.g. 20–27 May" />
        </div>
        <div class="form-group">
          <label class="form-label">Total Budget (NZD) *</label>
          <div class="input-prefix-wrap">
            <span class="input-prefix">$</span>
            <input class="form-input prefixed" type="number" id="t-budget" min="1" step="100" placeholder="2000" />
          </div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Category Budgets (optional)</label>
        <div class="cat-budget-grid" id="catBudgetInputs"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeModal('tripModal')">Cancel</button>
      <button class="btn btn-primary" onclick="submitTrip()">Create Trip</button>
    </div>
  </div>
</div>

<!-- ══ MODAL: ADD EXPENSE ════════════════════════════════════════ -->
<div class="modal-overlay hidden" id="expenseModal" onclick="if(event.target===this) closeModal('expenseModal')">
  <div class="modal">
    <div class="modal-handle"></div>
    <div class="modal-header">
      <span class="modal-title">Add Expense</span>
      <button class="modal-close" onclick="closeModal('expenseModal')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Description *</label>
        <input class="form-input" type="text" id="e-desc" placeholder="e.g. Lunch at taverna" />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Amount (NZD) *</label>
          <div class="input-prefix-wrap">
            <span class="input-prefix">$</span>
            <input class="form-input prefixed" type="number" id="e-amount" min="0.01" step="0.01" placeholder="0.00" />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Category *</label>
          <select class="form-select" id="e-category">
            <option value="0">🍽️ Food</option>
            <option value="1">🏨 Accommodation</option>
            <option value="2">🚗 Transport</option>
            <option value="3">🎭 Activities</option>
            <option value="4">🛍️ Shopping</option>
            <option value="5">💼 Other</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Date</label>
        <input class="form-input" type="date" id="e-date" />
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeModal('expenseModal')">Cancel</button>
      <button class="btn btn-primary" onclick="submitExpense()">Add Expense</button>
    </div>
  </div>
</div>

<!-- ══ MODAL: CATEGORY BUDGETS ══════════════════════════════════ -->
<div class="modal-overlay hidden" id="catBudgetModal" onclick="if(event.target===this) closeModal('catBudgetModal')">
  <div class="modal">
    <div class="modal-handle"></div>
    <div class="modal-header">
      <span class="modal-title">Category Budgets</span>
      <button class="modal-close" onclick="closeModal('catBudgetModal')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="cat-budget-grid" id="catBudgetEditInputs"></div>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeModal('catBudgetModal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveCatBudgets()">Save</button>
    </div>
  </div>
</div>

@section Scripts {
<script>
// ── Constants ──────────────────────────────────────────────────
const CATEGORIES = [
  { value: 0, name: 'Food',          icon: '🍽️', tint: '#FFF4E6' },
  { value: 1, name: 'Accommodation', icon: '🏨', tint: '#E6F4FF' },
  { value: 2, name: 'Transport',     icon: '🚗', tint: '#EFF6FF' },
  { value: 3, name: 'Activities',    icon: '🎭', tint: '#F4F0FF' },
  { value: 4, name: 'Shopping',      icon: '🛍️', tint: '#FFF0F9' },
  { value: 5, name: 'Other',         icon: '💼', tint: '#F0F4F8' }
];

// ── State ──────────────────────────────────────────────────────
let trips = [];
let activeTrip = null;
let donutChart = null;
let activeBudgetTripId = null;

// ── Init ───────────────────────────────────────────────────────
async function init() {
  const today = new Date().toISOString().slice(0, 10);
  document.getElementById('e-date').value = today;
  buildCatBudgetInputs('catBudgetInputs');
  await loadTrips();
  await loadProfile();
}

// ── Navigation ─────────────────────────────────────────────────
function switchTab(name) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  document.getElementById('nav-' + name).classList.add('active');

  if (name === 'expenses')  loadExpenses();
  if (name === 'budget')    initBudgetTab();
  if (name === 'profile')   loadProfile();
}

// ── Trips tab ──────────────────────────────────────────────────
async function loadTrips() {
  const res = await fetch('/api/trips');
  trips = await res.json();
  renderTrips();
}

function renderTrips() {
  const el = document.getElementById('tripsList');
  if (trips.length === 0) {
    el.innerHTML = `<div class="empty-state">
      <div class="empty-icon">🗺️</div>
      <div class="empty-title">No trips yet</div>
      <div class="empty-sub">Tap <strong>+ New Trip</strong> to plan your first adventure.</div>
    </div>`;
    return;
  }
  el.innerHTML = `<div class="trips-list">${trips.map(tripCard).join('')}</div>`;
}

function tripCard(t) {
  const pct = Math.min(t.spentPct, 100);
  const over = t.spentPct > 100;
  return `
    <div class="trip-card" onclick="openTrip('${t.id}')">
      <div class="trip-cover cover-${t.coverIndex}">
        <button class="trip-cover-delete" onclick="event.stopPropagation(); deleteTrip('${t.id}')">&times;</button>
        <div class="trip-info-panel" style="width:100%">
          <div class="trip-name">${esc(t.name)}</div>
          ${t.dateRange ? `<div class="trip-dates">${esc(t.dateRange)}</div>` : ''}
          <div class="trip-progress-row">
            <span class="trip-spent-label">$${fmt(t.totalSpent)} of $${fmt(t.totalBudget)}</span>
            <span class="trip-pct-label">${t.spentPct}%</span>
          </div>
          <div class="progress-track">
            <div class="progress-fill ${over ? 'over' : ''}" style="width:${pct}%"></div>
          </div>
        </div>
      </div>
    </div>`;
}

async function openTrip(id) {
  activeTrip = trips.find(t => t.id === id) || null;
  activeBudgetTripId = id;
  switchTab('expenses');
}

async function deleteTrip(id) {
  if (!confirm('Delete this trip and all its expenses?')) return;
  await fetch('/api/trips/' + id, { method: 'DELETE' });
  await loadTrips();
  if (activeTrip?.id === id) { activeTrip = null; }
  flash('Trip deleted');
}

async function submitTrip() {
  const name = document.getElementById('t-name').value.trim();
  const budget = parseFloat(document.getElementById('t-budget').value);
  if (!name) { flash('Trip name required', true); return; }
  if (!budget || budget <= 0) { flash('Budget required', true); return; }

  const catBudgets = {};
  CATEGORIES.forEach(c => {
    const v = parseFloat(document.getElementById('cb-' + c.value)?.value || '0');
    if (v > 0) catBudgets[c.value] = v;
  });

  const res = await fetch('/api/trips', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      name, dateRange: document.getElementById('t-dates').value.trim() || null,
      totalBudget: budget, coverIndex: null,
      categoryBudgets: Object.keys(catBudgets).length ? catBudgets : null
    })
  });
  if (!res.ok) { flash('Error creating trip', true); return; }
  const trip = await res.json();
  closeModal('tripModal');
  document.getElementById('t-name').value = '';
  document.getElementById('t-dates').value = '';
  document.getElementById('t-budget').value = '';
  CATEGORIES.forEach(c => { const el = document.getElementById('cb-' + c.value); if (el) el.value = ''; });
  await loadTrips();
  activeTrip = trips.find(t => t.id === trip.id) || null;
  flash('Trip created!');
}

// ── Expenses tab ───────────────────────────────────────────────
async function loadExpenses() {
  if (!activeTrip) {
    document.getElementById('expTrip').textContent = '—';
    document.getElementById('expSpentBadge').textContent = '';
    document.getElementById('expenseList').innerHTML = `<div class="empty-state">
      <div class="empty-icon">🧳</div>
      <div class="empty-title">No trip selected</div>
      <div class="empty-sub">Go to <strong>Trips</strong> and tap a trip to view its expenses.</div>
    </div>`;
    return;
  }
  const res = await fetch('/api/trips/' + activeTrip.id + '/expenses');
  const detail = await res.json();
  activeTrip = { ...activeTrip, ...detail };
  renderExpenses(detail);
}

function renderExpenses(detail) {
  document.getElementById('expTrip').textContent = detail.name;
  document.getElementById('expSpentBadge').textContent = '$' + fmt(detail.totalSpent) + ' spent';

  if (detail.expenses.length === 0) {
    document.getElementById('expenseList').innerHTML = `<div class="empty-state">
      <div class="empty-icon">💳</div>
      <div class="empty-title">No expenses yet</div>
      <div class="empty-sub">Tap <strong>+ Add</strong> to record your first expense.</div>
    </div>`;
    return;
  }

  document.getElementById('expenseList').innerHTML =
    detail.expenses.map(e => expenseRow(e, detail.id)).join('');
}

function expenseRow(e, tripId) {
  return `
    <div class="expense-row">
      <div class="expense-icon" style="background:${e.categoryTint}">${e.categoryIcon}</div>
      <div class="expense-body">
        <div class="expense-desc">${esc(e.description)}</div>
        <div class="expense-date">${e.date}</div>
      </div>
      <div class="expense-right">
        <span class="expense-amount">$${fmt(e.amount)}</span>
        <button class="icon-btn" onclick="deleteExpense('${tripId}', '${e.id}')">&times;</button>
      </div>
    </div>`;
}

async function deleteExpense(tripId, expId) {
  const res = await fetch(`/api/trips/${tripId}/expenses/${expId}`, { method: 'DELETE' });
  const detail = await res.json();
  activeTrip = { ...activeTrip, ...detail };
  renderExpenses(detail);
}

async function submitExpense() {
  if (!activeTrip) { flash('Select a trip first', true); return; }
  const desc = document.getElementById('e-desc').value.trim();
  const amount = parseFloat(document.getElementById('e-amount').value);
  const category = parseInt(document.getElementById('e-category').value);
  const date = document.getElementById('e-date').value;
  if (!desc || !amount || amount <= 0) { flash('Fill in all fields', true); return; }

  const res = await fetch('/api/trips/' + activeTrip.id + '/expenses', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ description: desc, amount, category, date: date ? date + 'T00:00:00' : null })
  });
  if (!res.ok) { flash('Error adding expense', true); return; }
  const detail = await res.json();
  activeTrip = { ...activeTrip, ...detail };
  renderExpenses(detail);
  closeModal('expenseModal');
  document.getElementById('e-desc').value = '';
  document.getElementById('e-amount').value = '';
}

// ── Budget tab ─────────────────────────────────────────────────
function initBudgetTab() {
  const sel = document.getElementById('budgetTripSelect');
  sel.innerHTML = trips.length === 0
    ? '<option>— No trips yet —</option>'
    : trips.map(t => `<option value="${t.id}" ${t.id === (activeBudgetTripId || trips[0]?.id) ? 'selected' : ''}>${esc(t.name)}</option>`).join('');

  const id = activeBudgetTripId || trips[0]?.id;
  if (id) loadBudget(id);
  else document.getElementById('budgetContent').innerHTML = `<div class="empty-state"><div class="empty-icon">📊</div><div class="empty-title">No trips yet</div></div>`;
}

async function loadBudget(tripId) {
  activeBudgetTripId = tripId;
  const res = await fetch('/api/trips/' + tripId + '/budget');
  if (!res.ok) return;
  const b = await res.json();
  renderBudget(b);
}

function renderBudget(b) {
  const pct = Math.min(b.spentPct, 100);
  const over = b.spentPct > 100;

  document.getElementById('budgetContent').innerHTML = `
    <div style="text-align:center;margin-bottom:.5rem">
      <div class="budget-total-label">Total Budget</div>
      <div class="budget-total-amount">$${fmt(b.totalBudget)}</div>
    </div>
    <div class="donut-wrap">
      <canvas id="donutCanvas" width="180" height="180"></canvas>
      <div class="donut-center">
        <div class="donut-pct">${b.spentPct}%</div>
        <div class="donut-label">Spent</div>
      </div>
    </div>
    <div class="budget-stats-row">
      <div class="stat-col">
        <span class="stat-label">Spent</span>
        <span class="stat-value">$${fmt(b.totalSpent)}</span>
      </div>
      <div class="stat-col">
        <span class="stat-label">Remaining</span>
        <span class="stat-value">$${fmt(b.remaining)}</span>
      </div>
    </div>
    <div class="categories-heading">
      Categories
      <button class="cat-budgets-btn" onclick="openCatBudgets('${b.tripId}')">Set Budgets</button>
    </div>
    <div class="category-rows">
      ${b.categories.filter(c => c.spent > 0 || c.budget > 0).map(catRow).join('')
        || '<div style="color:var(--gray);font-size:.8rem;text-align:center;padding:1rem 0">No expenses yet</div>'}
    </div>`;

  renderDonut(b);
}

function catRow(c) {
  const hasBudget = c.budget > 0;
  const pct = hasBudget ? Math.min(c.spentPct, 100) : 0;
  const over = hasBudget && c.spentPct > 100;
  const spentWidth = hasBudget ? pct
    : 0;
  return `
    <div class="category-row">
      <div class="cat-icon" style="background:${c.categoryTint}">${c.categoryIcon}</div>
      <div class="cat-body">
        <div class="cat-name-row">
          <span class="cat-name">${c.categoryName}</span>
          <span class="cat-amounts">${hasBudget ? `$${fmt(c.spent)} / $${fmt(c.budget)}` : `$${fmt(c.spent)}`}</span>
        </div>
        <div class="cat-bar-row">
          <div class="cat-track">
            <div class="cat-fill ${over ? 'over' : ''}" style="width:${spentWidth}%"></div>
          </div>
          <span class="cat-pct">${hasBudget ? c.spentPct + '%' : ''}</span>
        </div>
      </div>
    </div>`;
}

function renderDonut(b) {
  if (donutChart) { donutChart.destroy(); donutChart = null; }
  const canvas = document.getElementById('donutCanvas');
  if (!canvas) return;
  const spent = b.totalSpent;
  const remaining = Math.max(0, b.totalBudget - spent);
  const over = spent > b.totalBudget;
  donutChart = new Chart(canvas.getContext('2d'), {
    type: 'doughnut',
    data: {
      datasets: [{
        data: over ? [spent, 0] : [spent, remaining],
        backgroundColor: over ? ['#EF4444', '#EAF0F6'] : ['#14A89E', '#EAF0F6'],
        borderWidth: 0,
        borderRadius: 4
      }]
    },
    options: {
      cutout: '72%',
      responsive: false,
      plugins: { legend: { display: false }, tooltip: { enabled: false } },
      animation: { duration: 600, easing: 'easeInOutQuart' }
    }
  });
}

// ── Category budgets modal ─────────────────────────────────────
let editingBudgetTripId = null;

async function openCatBudgets(tripId) {
  editingBudgetTripId = tripId;
  const res = await fetch('/api/trips/' + tripId + '/budget');
  const b = await res.json();
  buildCatBudgetInputs('catBudgetEditInputs', b.categories);
  openModal('catBudgetModal');
}

function buildCatBudgetInputs(containerId, existingCats) {
  const el = document.getElementById(containerId);
  if (!el) return;
  el.innerHTML = CATEGORIES.map(c => {
    const existing = existingCats?.find(ec => ec.category === c.value);
    return `
      <div class="cat-budget-row">
        <span class="cat-budget-icon">${c.icon}</span>
        <input class="cat-budget-input" type="number" id="${containerId === 'catBudgetEditInputs' ? 'cbe' : 'cb'}-${c.value}"
          min="0" step="50" placeholder="${c.name}"
          value="${existing?.budget > 0 ? existing.budget : ''}" />
      </div>`;
  }).join('');
}

async function saveCatBudgets() {
  const budgets = {};
  CATEGORIES.forEach(c => {
    const v = parseFloat(document.getElementById('cbe-' + c.value)?.value || '0');
    if (v > 0) budgets[c.value] = v;
  });
  await fetch('/api/trips/' + editingBudgetTripId + '/category-budgets', {
    method: 'PUT', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ budgets })
  });
  closeModal('catBudgetModal');
  loadBudget(editingBudgetTripId);
  flash('Budgets saved!');
}

// ── Profile tab ────────────────────────────────────────────────
async function loadProfile() {
  const res = await fetch('/api/stats');
  const s = await res.json();
  document.getElementById('profileStats').innerHTML = `
    <div class="stat-card">
      <div class="stat-card-value">${s.tripCount}</div>
      <div class="stat-card-label">Trips</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-value">${s.expenseCount}</div>
      <div class="stat-card-label">Expenses</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-value">$${fmtK(s.totalSpent)}</div>
      <div class="stat-card-label">Spent</div>
    </div>`;

  document.getElementById('recentExpenses').innerHTML = s.recentExpenses.length === 0
    ? `<div class="empty-state"><div class="empty-sub">No expenses yet.</div></div>`
    : s.recentExpenses.map(e => `
        <div class="expense-row">
          <div class="expense-icon" style="background:${e.categoryTint}">${e.categoryIcon}</div>
          <div class="expense-body">
            <div class="expense-desc">${esc(e.description)}</div>
            <div class="expense-date">${e.date}</div>
          </div>
          <div class="expense-right">
            <span class="expense-amount">$${fmt(e.amount)}</span>
          </div>
        </div>`).join('');
}

// ── Modals ─────────────────────────────────────────────────────
function openModal(id) {
  document.getElementById(id).classList.remove('hidden');
  const firstInput = document.querySelector(`#${id} input, #${id} select`);
  setTimeout(() => firstInput?.focus(), 80);
}

function closeModal(id) {
  document.getElementById(id).classList.add('hidden');
}

// ── Helpers ────────────────────────────────────────────────────
function fmt(n)  { return Number(n).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ','); }
function fmtK(n) {
  if (n >= 1000) return '$' + (n/1000).toFixed(1) + 'k';
  return fmt(n);
}
function esc(s) {
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

let _flashTimer;
function flash(msg, err = false) {
  let el = document.getElementById('__flash');
  if (!el) { el = document.createElement('div'); el.id = '__flash'; document.body.appendChild(el); }
  el.textContent = msg;
  el.className = 'flash-msg' + (err ? ' flash-err' : '');
  clearTimeout(_flashTimer);
  _flashTimer = setTimeout(() => el.classList.add('hidden'), 2500);
}

init();
</script>
}
